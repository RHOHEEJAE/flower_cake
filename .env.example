# Supabase (필수)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 카카오 직접 OAuth (KOE205 회피: Supabase가 붙이는 account_email 없이 인가)
# REST API 키 = Client ID, 카카오 로그인 Client Secret = 동일 앱의 시크릿
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# 이메일 가입 후 리다이렉트 (선택, 로컬 기본은 사이트 origin)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/

# 카카오 로그인: Supabase 대시보드 Redirect URL에
# http://localhost:3000/auth/callback
# 을 등록하세요. 자세한 내용은 docs/supabase-oauth-setup.md 참고
