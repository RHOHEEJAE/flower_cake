# ── 네이버 로그인 API ───────────────────────────────────────────
# 발급처: https://developers.naver.com → 애플리케이션 등록
NAVER_CLIENT_ID=발급받은_클라이언트_ID
NAVER_CLIENT_SECRET=발급받은_클라이언트_시크릿
NAVER_CALLBACK_URL=http://localhost:4000/api/auth/naver/callback

# ── 카카오 로그인 API ───────────────────────────────────────────
# 발급처: https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_CLIENT_ID=발급받은_REST_API_키
KAKAO_CLIENT_SECRET=발급받은_클라이언트_시크릿
KAKAO_CALLBACK_URL=http://localhost:4000/api/auth/kakao/callback

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=여기에_랜덤_긴_문자열_입력_최소_32자_이상
JWT_EXPIRES_IN=7d

# ── 서버/클라이언트 ────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173

# ── 관리자 계정 (seed.js에서 초기 생성) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234!
